<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>新概念英语 on Kevin Lee's Blog</title><link>https://080812.xyz/categories/newconceptenglish/</link><description>Recent content in 新概念英语 on Kevin Lee's Blog</description><generator>Hugo -- gohugo.io</generator><language>zh-cn</language><copyright>Kevin Lee's Blog</copyright><lastBuildDate>Sun, 10 Mar 2024 11:18:52 +0800</lastBuildDate><atom:link href="https://080812.xyz/categories/newconceptenglish/index.xml" rel="self" type="application/rss+xml"/><item><title>新概念英语 第一册 01-24</title><link>https://080812.xyz/p/nce1-01/</link><pubDate>Sun, 10 Mar 2024 11:18:52 +0800</pubDate><guid>https://080812.xyz/p/nce1-01/</guid><description>&lt;h2 id="lesson-1-excuse-me">Lesson 1 Excuse me&lt;/h2>
&lt;h3 id="text">Text&lt;/h3>
&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;span class="lnt">3
&lt;/span>&lt;span class="lnt">4
&lt;/span>&lt;span class="lnt">5
&lt;/span>&lt;span class="lnt">6
&lt;/span>&lt;span class="lnt">7
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">Excuse me!
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Yes?
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Is this your handbag?
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Pardon?
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Is this your handbag?
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Yes, it is.
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Thank you very much.
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h3 id="notes">Notes&lt;/h3>
&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt"> 1
&lt;/span>&lt;span class="lnt"> 2
&lt;/span>&lt;span class="lnt"> 3
&lt;/span>&lt;span class="lnt"> 4
&lt;/span>&lt;span class="lnt"> 5
&lt;/span>&lt;span class="lnt"> 6
&lt;/span>&lt;span class="lnt"> 7
&lt;/span>&lt;span class="lnt"> 8
&lt;/span>&lt;span class="lnt"> 9
&lt;/span>&lt;span class="lnt">10
&lt;/span>&lt;span class="lnt">11
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">1.Excuse me! 动词，使对方注意自己
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">在汉语中的意思是原谅我！
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">2.陈述句和一般疑问句
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">陈述句中Be动词提前变疑问句
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">This is ...
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Is this ...?
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">3．Pardon？感叹词，意为：对不起，请再说一遍。
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">当我们没听清或没理解对方的话并希望对方能重复一遍时，就可以使用这一表达方式。
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">在汉语中的意思相当于&amp;#34;对不起，请再说一遍&amp;#34;或者&amp;#34;对不起，请再说一遍好吗？&amp;#34;
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h3 id="grammar">Grammar&lt;/h3>
&lt;p>一、主谓宾&lt;/p>
&lt;p>&lt;code>名词在主词位置用主格,宾语位置用宾格.&lt;/code>&lt;/p>
&lt;style>
.center
{
width: auto;
display: table;
margin-left: auto;
margin-right: auto;
}
&lt;/style>
&lt;div class="center">
&lt;table>
&lt;thead>
&lt;tr>
&lt;th style="text-align:center">主格&lt;/th>
&lt;th style="text-align:center">宾格&lt;/th>
&lt;th style="text-align:center">形容词性物主代词&lt;/th>
&lt;/tr>
&lt;/thead>
&lt;tbody>
&lt;tr>
&lt;td style="text-align:center">I&lt;/td>
&lt;td style="text-align:center">me&lt;/td>
&lt;td style="text-align:center">my&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td style="text-align:center">you&lt;/td>
&lt;td style="text-align:center">you&lt;/td>
&lt;td style="text-align:center">your&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td style="text-align:center">he&lt;/td>
&lt;td style="text-align:center">him&lt;/td>
&lt;td style="text-align:center">his&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td style="text-align:center">she&lt;/td>
&lt;td style="text-align:center">her&lt;/td>
&lt;td style="text-align:center">her&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td style="text-align:center">it&lt;/td>
&lt;td style="text-align:center">it&lt;/td>
&lt;td style="text-align:center">its&lt;/td>
&lt;/tr>
&lt;/tbody>
&lt;/table>
&lt;/div>
&lt;p>&lt;code>形容词性物主代词:表示所属关系，对应汉语中的 “我的” “你的” “TA的”。&lt;/code>&lt;/p>
&lt;p>二、陈述句-&amp;gt;疑问句&lt;/p>
&lt;p>This &lt;u>is&lt;/u> a car. -&amp;gt; &lt;u>Is&lt;/u> this your car?&lt;/p>
&lt;p>① Be动词放句子最开头.&lt;/p>
&lt;p>② 陈述句降调变疑问句的升词。&lt;/p>
&lt;p>三、回答 Is this &amp;hellip;? 的提问&lt;/p>
&lt;ul>
&lt;li>
&lt;p>肯定：Yes,it is.   &lt;code>it is 连读&lt;/code>&lt;/p>
&lt;/li>
&lt;li>
&lt;p>否定：No,it isn&amp;rsquo;t.   &lt;code>isn't = is not &lt;/code>&lt;/p>
&lt;/li>
&lt;/ul>
